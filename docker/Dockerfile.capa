# Mandiant FLARE capa — capability detection for malware analysis.
# Detects capabilities and ATT&CK/MBC techniques in PE, ELF, and shellcode.
FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends libmagic1 \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir flare-capa

WORKDIR /mnt/staging
CMD ["/bin/sh"]
