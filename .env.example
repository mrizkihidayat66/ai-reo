# AI-REO Environment Configuration
# Copy this file to .env and fill in your values.

# Note: LLM Provider Settings (API keys, models, URLs) are no longer managed
# in this file. They are configured entirely at runtime via the web UI.

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
AI_REO_HOST=127.0.0.1
AI_REO_PORT=8000
AI_REO_LOG_LEVEL=info

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Absolute path for the SQLite database file.
# Defaults to tmp/.ai-reo/sessions.db if not set.
AI_REO_DATABASE_URL=sqlite:///~/.ai-reo/sessions.db

# ------------------------------------------------------------------
# Tool Integration & Storage
# ------------------------------------------------------------------
# Directory where analysis sessions and binaries are stored.
# Defaults to tmp/.ai-reo/sessions if not set.
AI_REO_SESSIONS_DIR=tmp/.ai-reo/sessions

# Docker network used by tool containers.
AI_REO_DOCKER_NETWORK=ai-reo-tools
