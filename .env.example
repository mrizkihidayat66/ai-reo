# AI-REO Environment Configuration
# Copy this file to .env and fill in your values.

# Note: LLM Provider Settings (API keys, models, URLs) are no longer managed
# in this file. They are configured entirely at runtime via the web UI.

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
AI_REO_HOST=127.0.0.1
AI_REO_PORT=9000
AI_REO_LOG_LEVEL=info

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Absolute path for the SQLite database file.
# Defaults to tmp/.ai-reo/sessions.db if not set.
AI_REO_DATABASE_URL=sqlite:///./tmp/.ai-reo/sessions/sessions.db

# ------------------------------------------------------------------
# Tool Integration & Storage
# ------------------------------------------------------------------
# Directory where analysis sessions and binaries are stored.
# Defaults to tmp/.ai-reo/sessions if not set.
AI_REO_SESSIONS_DIR=tmp/.ai-reo/sessions

# Docker network used by tool containers.
AI_REO_DOCKER_NETWORK=ai-reo-tools

# Maximum number of tool-call rounds per agent step (default: 32).
AI_REO_MAX_TOOL_ROUNDS=32

# Maximum ZIP file upload size in MB (default: 512 MB).
# Increase this if you need to upload larger archived binaries.
AI_REO_MAX_UPLOAD_SIZE_MB=512

# Directory for persistent agent-generated reusable scripts.
# Defaults to tmp/.ai-reo/scripts (repo-local).
# Override to a path outside the repo to persist scripts across checkouts.
# AI_REO_SCRIPTS_DIR=tmp/.ai-reo/scripts

# --- Production overrides (not needed for local development) ---------------------
# By default, skills and agents are loaded from the bundled skills/ and agents/ dirs at the repo root.
# Set these only if you want to load customised versions from outside the repo.
# AI_REO_SKILLS_DIR=~/.ai-reo/skills
# AI_REO_AGENTS_DIR=~/.ai-reo/agents
